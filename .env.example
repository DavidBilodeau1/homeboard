# Your Home Assistant base URL (no trailing slash)
HA_URL=https://homeassistant.example.com

# Long-lived access token: HA → your profile (bottom-left) → Security →
# "Long-lived access tokens" → Create token
HA_TOKEN=paste-your-token-here

# Immich photo slideshow (optional — falls back to the ./photos folder)
IMMICH_URL=https://photos.example.com
# Immich → Account Settings → API Keys (same key as your HA wallpanel config)
IMMICH_API_KEY=paste-your-immich-key-here
IMMICH_ALBUM=Wallpanel

# "Log in with Home Assistant" — REQUIRED when hosting HomeBoard publicly.
# Set this to HomeBoard's own externally reachable URL (NOT your HA URL).
# Once set, every visitor must log in through your Home Assistant.
# Leave empty to keep the dashboard open (trusted LAN only).
PUBLIC_URL=https://homeboard.example.com
# Optional: pin the cookie-signing secret (else auto-generated & persisted).
# SESSION_SECRET=some-long-random-string
